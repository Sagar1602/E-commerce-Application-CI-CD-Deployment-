# ---------------------------------------------------------------------------
# Nexus Repository Manager - npm configuration
# ---------------------------------------------------------------------------
# Point npm at your Nexus "npm group" repository (a group that aggregates the
# hosted repo + the npmjs proxy). Replace the host/port with your Nexus URL.
#
# In CI/CD the auth token is injected from a secret (see github workflow),
# so DO NOT commit a real token here.
# ---------------------------------------------------------------------------

registry=http://your-nexus-host:8081/repository/npm-group/

# Auth for publishing to the hosted repo / pulling from a private group.
# ${NPM_TOKEN} is substituted from the environment at install/publish time.
//your-nexus-host:8081/repository/npm-group/:_authToken=${NPM_TOKEN}
//your-nexus-host:8081/repository/npm-hosted/:_authToken=${NPM_TOKEN}

# Be strict about SSL only if your Nexus serves valid HTTPS certs.
strict-ssl=false
always-auth=true
